APP_URL="http://localhost:3000"
PORT="3001"

# Backend-owned providers
GEMINI_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# Optional model overrides
# Defaults:
# - chat / reasoning: gemini-2.5-flash
# - live voice: gemini-2.5-flash-native-audio-preview-12-2025
# - image: gemini-2.5-flash-image
# - video: veo-3.1-fast-generate-preview
GEMINI_CHAT_MODEL=""
GEMINI_REASONING_MODEL=""
GEMINI_LIVE_MODEL=""
GEMINI_IMAGE_MODEL=""
GEMINI_VIDEO_MODEL=""

# Persistence
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lensiq"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_AUTH_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"
SESSION_SECRET=""

# Optional object storage
GCS_BUCKET=""
GCS_PROJECT_ID=""

# Optional future adapters
# MCP / GenMedia hooks are config-driven and reuse the existing backend provider keys.

# Optional UI hint
VITE_ENABLE_CREATIVE_TOOLS="true"
